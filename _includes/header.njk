<header>

  <a href="#main" id="skip" title="skip to main content">skip to main content</a>

  <a class="site-title" href="/"
    {% if page.url == "/" %}aria-current="page"{% endif %}
    {% if "/" == page.url | stripPageNumber %}data-current-section="true"{% endif %}>
    Home</a>

  <div class="folder-background"></div>

  <nav aria-label="main navigation">
    <ul>
      <li><a href="/about/"
        {% if "/about/" == page.url %}aria-current="page" data-current-section="true"{% endif %}>
        About</a></li>
      <li><a href="/blog/"
        {% if "/blog/" == page.url %}aria-current="page"{% endif %}
        {% if "/blog/" == page.url | stripPageNumber %}data-current-section="true"{% endif %}>
        Blog</a></li>
      <li><a href="/contact/"
        {% if "/contact/" == page.url %}aria-current="page" data-current-section="true"{% endif %}>
        Contact</a></li>
    </ul>
  </nav>

</header>
