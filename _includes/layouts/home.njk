---
layout: listpage.njk
pagination:
  data: collections.highlight
  size: 2
  alias: postlist
  reverse: true
eleventyComputed:
  permalink: /{% if pagination.pageNumber %}{{ pagination.pageNumber }}/{% endif %}
---

{% if pagination.pageNumber == 0 %}
  <h2 class="subtitle">{{ subtitle }}</h2>

  {% if hero.image %}
    <img class="home hero" src="{{ hero.image }}" alt="{{ hero.alt }}">
  {% endif %}

  {{ content | safe }}

  <h2 class="center-h2">Highlights</h2>
{% endif %}

{% include "postlist.njk" %}
